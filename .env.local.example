# Local development overrides — copy this file to .env.local to enable features
# .env.local is git-ignored and will override .env settings locally

# Enable mini-games for local testing:
# NEXT_PUBLIC_FEATURE_CTF=true
# NEXT_PUBLIC_FEATURE_PIXEL_WARS=true
# NEXT_PUBLIC_FEATURE_TOWER_DEFENSE=true
# NEXT_PUBLIC_FEATURE_TILE_CHALLENGES=true

# Enable social features for local testing:
# NEXT_PUBLIC_FEATURE_ALLIANCES=true
# NEXT_PUBLIC_FEATURE_BOUNTIES=true
# NEXT_PUBLIC_FEATURE_CHALLENGES=true
