# Casper Testnet deployment environment
# Copy to .env and fill in values before deploying

# -- Node RPC --
ODRA_CASPER_LIVENET_NODE_ADDRESS=https://node.testnet.casper.network/rpc
ODRA_CASPER_LIVENET_EVENTS_URL=https://events.testnet.casper.network/events/main
ODRA_CASPER_LIVENET_CHAIN_NAME=casper-test

# -- Deployer key --
ODRA_CASPER_LIVENET_SECRET_KEY_PATH=/home/jeanclaude/.casper/testnet-deploy-key/secret_key.pem

# -- Contract parameters --
# wCSPR contract hash on testnet (CEP-18 token)
# TODO: Find or deploy a wCSPR CEP-18 token on testnet
WCSPR_CONTRACT=hash-PLACEHOLDER

# Treasury address (receives wCSPR payments)
TREASURY_PUBKEY=0196f363185dc4b746109bddcf27632c506fec460cf4a0363801e1e3729ac6fb7f

# -- x402 Facilitator --
# API key for x402-facilitator.cspr.cloud testnet
# TODO: Obtain from CSPR.cloud console
CASPER_FACILITATOR_API_KEY=PLACEHOLDER
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud/
