PRIVATE_KEY=your_private_key_here
BASESCAN_API_KEY=your_basescan_api_key_here

# -- CSPR.click SDK (Casper wallet integration) --
# Register at https://console.cspr.build to get your App ID
NEXT_PUBLIC_CSPRCLICK_APP_ID=your_csprclick_app_id_here
# Set to "casper-test" for testnet, "casper" for mainnet (default: mainnet)
NEXT_PUBLIC_CASPER_NETWORK=casper

# ── Feature flags (mini-game modules) ─────────────────────────────────────────
# Set to "true" to enable. Default is OFF so unfinished games don't ship.
# Core game flags (Decision #141 Option B — off by default):
NEXT_PUBLIC_FEATURE_CTF=false
NEXT_PUBLIC_FEATURE_PIXEL_WARS=false
NEXT_PUBLIC_FEATURE_TOWER_DEFENSE=false
NEXT_PUBLIC_FEATURE_TILE_CHALLENGES=false

# Social/coordination expansion flags (off by default):
NEXT_PUBLIC_FEATURE_ALLIANCES=false
NEXT_PUBLIC_FEATURE_BOUNTIES=false
NEXT_PUBLIC_FEATURE_CHALLENGES=false
